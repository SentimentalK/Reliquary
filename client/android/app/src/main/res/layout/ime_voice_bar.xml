<?xml version="1.0" encoding="utf-8"?>
<!--
    Keyboard layout:
    Status Pill (top)
    3-column grid: Up/Down | PTT Mic | Backspace+Enter
    Symmetric left/right, uniform #F3F4F6 background.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F3F4F6"
    android:gravity="bottom">

    <!-- ===== Status Pill ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="14dp">

        <LinearLayout
            android:id="@+id/status_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_status_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/status_dot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textSize="8sp"
                android:textColor="#374151" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginStart="6dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02" />
        </LinearLayout>
    </FrameLayout>

    <!-- ===== 3-Column Keyboard Grid ===== -->
    <!-- Weights: Left 0.8 (Up/Down) | Center 1.6 (PTT) | Right 0.8 (BS/Enter) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="20dp">

        <!-- ===== LEFT ZONE: Up / Down (weight=0.8) ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            android:orientation="vertical"
            android:paddingEnd="10dp">

            <!-- Up Arrow (top half) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp">
                <ImageButton
                    android:id="@+id/btn_arrow_up"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_kb_button"
                    android:src="@drawable/ic_arrow_up"
                    android:scaleType="centerInside"
                    android:contentDescription="Up"
                    android:stateListAnimator="@null" />
            </FrameLayout>

            <!-- Down Arrow (bottom half) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="4dp">
                <ImageButton
                    android:id="@+id/btn_arrow_down"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_kb_button"
                    android:src="@drawable/ic_arrow_down"
                    android:scaleType="centerInside"
                    android:contentDescription="Down"
                    android:stateListAnimator="@null" />
            </FrameLayout>
        </LinearLayout>

        <!-- ===== CENTER ZONE: PTT Mic Button (weight=1.6) ===== -->
        <FrameLayout
            android:id="@+id/btn_ptt_container"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.6"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_kb_button">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/iv_ptt_mic"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:src="@drawable/ic_mic_large"
                    android:scaleType="centerInside"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_ptt_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOLD"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:alpha="0.6"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Ripple overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground" />
        </FrameLayout>

        <!-- ===== RIGHT ZONE: Backspace + Enter (weight=0.8) ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <!-- Backspace (top half) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp">
                <ImageButton
                    android:id="@+id/btn_backspace"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_kb_button"
                    android:src="@drawable/ic_backspace_dark"
                    android:scaleType="centerInside"
                    android:contentDescription="Backspace"
                    android:stateListAnimator="@null" />
            </FrameLayout>

            <!-- Enter (bottom half, dark) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="4dp">
                <ImageButton
                    android:id="@+id/btn_enter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_kb_button_enter"
                    android:src="@drawable/ic_enter"
                    android:scaleType="centerInside"
                    android:contentDescription="Enter"
                    android:stateListAnimator="@null" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>