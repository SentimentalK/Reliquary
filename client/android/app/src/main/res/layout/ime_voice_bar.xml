<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F2F2F7"
    android:gravity="bottom">

    <!-- 
      键盘主体容器 
      paddingHorizontal: 左右留白
      paddingTop: 顶部留白
      paddingBottom: 底部留白 (34dp 是标准 iOS Home Indicator 避让高度)
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="34dp"
        android:clipToPadding="false">

        <!-- Left: Switch IME (Square-ish) -->
        <ImageButton
            android:id="@+id/btn_switch_ime"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_ios_button"
            android:src="@drawable/ic_globe"
            android:scaleType="centerInside"
            android:padding="14dp"
            android:contentDescription="Switch Keyboard"
            android:elevation="2dp"
            android:stateListAnimator="@null" />

        <!-- Center: Mic Button (The Island) -->
        <!-- 使用 weight=1 占满中间空间 -->
        <FrameLayout
            android:id="@+id/btn_mic_container"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_ios_button"
            android:elevation="3dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Mic Icon Container (Light Blue Circle) -->
            <ImageView
                android:id="@+id/iv_mic_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic_filled"
                android:background="@drawable/bg_mic_circle_light"
                android:padding="6dp" />
            
            <!-- Ripple Effect Overlay (Optional for touch feedback) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/selectableItemBackground" />
        </FrameLayout>

        <!-- Right: Backspace (Square-ish) -->
        <ImageButton
            android:id="@+id/btn_backspace"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_ios_button"
            android:src="@drawable/ic_backspace"
            android:scaleType="centerInside"
            android:padding="15dp"
            android:contentDescription="Backspace"
            android:elevation="2dp"
            android:stateListAnimator="@null" />

    </LinearLayout>
</LinearLayout>