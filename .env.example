# =============================================================================
# Reliquary Docker Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values

# Pipeline Configuration
# Options: raw, llm_corrected
DEFAULT_PIPELINE=raw_whisper

# Authentication - Invite Codes (change these in production!)
ADMIN_INVITE_CODE=reliquary-admin-2026
USER_INVITE_CODE=reliquary-user-2026

# Set to false to disable authentication (development only)
REQUIRE_AUTH=true
# Groq API Key (Only needed when REQUIRE_AUTH is false)
GROQ_API_KEY=your_groq_api_key_here

# Frontend port (default: 3000)
FRONTEND_PORT=3000
# Backend port (default: 8080)
BACKEND_PORT=8080
