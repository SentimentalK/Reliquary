# =============================================================================
# Vortex Docker Environment Configuration
# =============================================================================
# Copy this file to .env and customize the values

# Groq API Key (required for ASR functionality)
GROQ_API_KEY=your_groq_api_key_here

# Pipeline Configuration
# Options: raw, llm_corrected
DEFAULT_PIPELINE=raw

# Authentication - Invite Codes (change these in production!)
ADMIN_INVITE_CODE=vortex-admin-2026
USER_INVITE_CODE=vortex-user-2026

# Set to false to disable authentication (development only)
REQUIRE_AUTH=true

# Frontend port (default: 3000)
FRONTEND_PORT=3000
